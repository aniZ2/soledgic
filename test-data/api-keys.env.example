# Soledgic Test API Keys (Example)
# =================================
# Copy to test-data/api-keys.env (untracked) and fill with local test keys.
# NEVER commit real keys.

# Example Test Ledger
SOLEDGIC_API_KEY=sk_test_replace_with_local_key
SOLEDGIC_LEDGER_ID=00000000-0000-0000-0000-000000000000
SOLEDGIC_LEDGER_NAME=Example Marketplace

# API Endpoint for local test scripts
SOLEDGIC_API_URL=https://ocjrcsmoeikxfooeglkt.supabase.co/functions/v1

# Optional MCP settings
# SOLEDGIC_BASE_URL=https://api.soledgic.com/v1
# SOLEDGIC_ALLOWED_TOOLS=get_balance,get_transactions,create_checkout
# SOLEDGIC_ALLOW_WRITES=false
# SOLEDGIC_ALLOW_LIVE_WRITES=false
# SOLEDGIC_ACTOR=codex

# Supabase Anon Key (required to access Edge Functions)
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
