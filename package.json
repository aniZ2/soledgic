{
  "name": "soledgic",
  "version": "1.0.0",
  "description": "Soledgic - Double-Entry Accounting for Creator Platforms",
  "private": true,
  "scripts": {
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:migrate": "supabase db push",
    "supabase:seed": "supabase db seed",
    "functions:serve": "supabase functions serve",
    "functions:deploy": "supabase functions deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:stress": "vitest run --config vitest.stress.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:mutate": "stryker run",
    "test:mutate:incremental": "stryker run --incremental",
    "graph:query": "node scripts/graph-query.mjs",
    "graph:impact": "node scripts/graph-impact.mjs",
    "graph:health": "node scripts/graph-health.mjs",
    "graph:enforce": "node scripts/graph-health.mjs --enforce",
    "arch:simulate": "node scripts/arch-simulate.mjs",
    "arch:simulate:pr": "node scripts/arch-simulate.mjs --pr",
    "arch:validate-financial": "node scripts/arch-validate-financial.mjs",
    "arch:critical-gate": "node scripts/arch-critical-path-gate.mjs",
    "arch:critical-gate:full": "node scripts/arch-critical-path-gate.mjs --full",
    "arch:analyze": "node scripts/arch-analyze.mjs",
    "arch:analyze:json": "node scripts/arch-analyze.mjs --json",
    "arch:reality-check": "node scripts/arch-reality-check.mjs",
    "seed:demo": "node scripts/seed-demo-data.mjs",
    "arch:propose": "node scripts/arch-propose.mjs",
    "arch:propose:json": "node scripts/arch-propose.mjs --json",
    "validate:env": "bash scripts/validate-env.sh",
    "security-gate": "bash scripts/security-gate.sh",
    "deploy:functions": "npm run security-gate && bash scripts/deploy-all-functions.sh",
    "deploy:migrations": "npm run security-gate && npx supabase db push",
    "check:runbooks": "tsx scripts/runbook-check.ts",
    "validate:index": "node scripts/validate-repo-index.mjs && node scripts/validate-repo-tools.mjs",
    "validate:tools": "node scripts/validate-repo-tools.mjs",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "validate:docs": "tsx scripts/validate-docs.ts",
    "validate:schema": "node scripts/validate-schema-hygiene.mjs",
    "test:unit": "cd supabase && deno test --no-check --allow-env --allow-read functions/_shared/__tests__/",
    "test:ecosystem": "node scripts/test-ecosystem-multi-platform.mjs",
    "test:ecosystem:cleanup": "node scripts/cleanup-ecosystem-multi-platform.mjs"
  },
  "keywords": [
    "accounting",
    "ledger",
    "double-entry",
    "creator-economy",
    "revenue-split",
    "supabase"
  ],
  "author": "Soledgic",
  "license": "UNLICENSED",
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "vitest": "^4.0.16",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0"
  }
}
