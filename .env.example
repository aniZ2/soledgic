# Soledgic Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# SUPABASE (Required)
# ============================================================================

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (safe for client-side)
SUPABASE_ANON_KEY=eyJ...your-anon-key

# Supabase service role key (server-side only, KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# For Next.js client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ============================================================================
# PAYMENT PROVIDER SELECTION
# ============================================================================

# Which payment backend to use: "stripe" (default) or "finix"
PAYMENT_PROVIDER=stripe

# ============================================================================
# STRIPE (Required when PAYMENT_PROVIDER=stripe)
# ============================================================================

# Stripe LIVE secret key (server-side only, KEEP SECRET)
# Used for live-mode ledgers (slk_live_* Soledgic API keys)
STRIPE_SECRET_KEY=sk_live_...

# Stripe TEST secret key (server-side only, KEEP SECRET)
# Used for test-mode ledgers (slk_test_* Soledgic API keys)
# When Soledgic is still in Stripe test mode, set both to the same sk_test_* key
STRIPE_TEST_SECRET_KEY=sk_test_...

# Stripe publishable key (safe for client-side)
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe LIVE webhook signing secret (for signature verification)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe TEST webhook signing secret (test-mode webhooks use a different secret)
STRIPE_TEST_WEBHOOK_SECRET=whsec_...

# Optional: separate secret for billing webhooks (falls back to STRIPE_WEBHOOK_SECRET)
STRIPE_BILLING_WEBHOOK_SECRET=

# ============================================================================
# CARD PROCESSOR / FINIX (Required when PAYMENT_PROVIDER=finix)
# ============================================================================

# Primary processor credentials (server-side only, KEEP SECRET)
PROCESSOR_USERNAME=
PROCESSOR_PASSWORD=

# sandbox or production
PROCESSOR_ENV=sandbox

# Required base URL for the processor API
PROCESSOR_BASE_URL=https://api.example-processor.com

# Required merchant / settlement configuration (server-side only)
PROCESSOR_MERCHANT_ID=

# Optional versioning headers (set if your processor requires them)
PROCESSOR_API_VERSION=
PROCESSOR_VERSION_HEADER=

# Optional path override for transfer/charge endpoints
PROCESSOR_TRANSFERS_PATH=/transfers

# Optional path template for refunds/reversals (use `{id}` for the payment id)
PROCESSOR_REFUNDS_PATH_TEMPLATE=/transfers/{id}/reversals

# Source id used for outbound payouts (server-side only)
PROCESSOR_PAYOUT_SOURCE_ID=

# Processor application + hosted onboarding forms (optional)
PROCESSOR_APPLICATION_ID=
PROCESSOR_ONBOARDING_FORM_ID=

# Hosted form for collecting an org billing method (can be the same as PROCESSOR_ONBOARDING_FORM_ID if configured that way)
PROCESSOR_BILLING_ONBOARDING_FORM_ID=

# ============================================================================
# PROCESSOR WEBHOOKS (Optional)
# ============================================================================

# Protect /api/webhooks/processor with a shared token (recommended for production).
# Send via: Authorization: Bearer <token> OR x-soledgic-webhook-token: <token>
PROCESSOR_WEBHOOK_TOKEN=

# Webhook normalization adapter (whitelabeled). Default: auto
PROCESSOR_WEBHOOK_ADAPTER=auto

# Amount unit used in webhook payloads: minor (default) or major
PROCESSOR_AMOUNT_UNIT=minor

# Enable event-driven dispute holds (moves creator funds to a dispute reserve).
# Default: false (recommended until dispute event mapping is validated).
PROCESSOR_WEBHOOK_ENABLE_DISPUTE_HOLDS=false

# Optional token to invoke internal processor inbox worker without the service role key
PROCESS_PROCESSOR_INBOX_TOKEN=

# ============================================================================
# BILLING (Usage-Based Overages)
# ============================================================================

# Platform merchant + destination used to charge overages (server-side only)
BILLING_MERCHANT_ID= # Optional override, otherwise uses PROCESSOR_MERCHANT_ID
BILLING_DESTINATION_ID=

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================

RESEND_API_KEY=re_...
FROM_EMAIL=noreply@soledgic.com

# ============================================================================
# SECURITY
# ============================================================================

# Secret for cron job authentication (health checks, cleanup)
CRON_SECRET=your-random-secret-here

# ============================================================================
# ERROR TRACKING (Sentry)
# ============================================================================

# Sentry DSN for server-side / edge functions
SENTRY_DSN=

# Sentry DSN for browser-side (Next.js client)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry org and project for source map uploads (CI only)
SENTRY_ORG=soledgic
SENTRY_PROJECT=soledgic-web
SENTRY_AUTH_TOKEN=

# ============================================================================
# MERCURY (ACH payouts)
# ============================================================================

MERCURY_API_KEY=
MERCURY_ACCOUNT_ID=

# ============================================================================
# OPS MONITORING & ALERTS
# ============================================================================

# Ops monitor alerts
OPS_SLACK_WEBHOOK_URL=
OPS_ALERT_EMAIL=

# Security alert recipient
SECURITY_ALERT_EMAIL=security@soledgic.com

# App URL (used in emails, checkout redirects)
APP_URL=https://soledgic.com

# ============================================================================
# INTERNAL TOKENS (edge function auth)
# ============================================================================

# Internal function-to-function auth token
SOLEDGIC_INTERNAL_FUNCTION_TOKEN=

# Platform bootstrap token (first-time setup)
PLATFORM_BOOTSTRAP_TOKEN=

# Bill overages cron token
BILL_OVERAGES_TOKEN=

# ============================================================================
# DEVELOPMENT
# ============================================================================

# Set to 'development' for local, 'production' for deployed
NODE_ENV=development

# Local development port
PORT=3000
