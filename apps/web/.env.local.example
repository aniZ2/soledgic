# Supabase (get these from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payment processor (Finix)
PROCESSOR_USERNAME=USxxxxxxx
PROCESSOR_PASSWORD=xxxxxxx
PROCESSOR_ENV=sandbox
PROCESSOR_BASE_URL=https://finix.sandbox-payments-api.com
PROCESSOR_MERCHANT_ID=MUxxxxxxx
PROCESSOR_API_VERSION=2022-02-01
PROCESSOR_VERSION_HEADER=Finix-Version

# Email (Resend)
RESEND_API_KEY=re_xxxxxxx

# Security
CSRF_ALLOWED_ORIGINS=http://localhost:3000
SOLEDGIC_INTERNAL_FUNCTION_TOKEN=your_internal_token_here

# Optional
# CRON_SECRET=your_cron_secret
